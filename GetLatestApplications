import json
import boto3
from decimal import Decimal

class DecimalEncoder(json.JSONEncoder):
    def default(self, obj):
        if isinstance(obj, Decimal):
            return str(obj)
        return super(DecimalEncoder, self).default(obj)

dynamodb = boto3.resource('dynamodb')
table = dynamodb.Table('ApplicantData') 

def lambda_handler(event, context):
    try:
        response = table.scan()
        items = response.get('Items', [])

        valid_applicants = []
        for item in items:
            app_id = item.get('ApplicantID')
            timestamp = item.get('SubmissionTimestamp', '')

            if not app_id or app_id == "ApplicantSequenceCounter":
                continue
            
            if not str(timestamp).startswith("20"):
                continue

            valid_applicants.append(item)

        # Sort Newest first
        valid_applicants.sort(key=lambda x: x.get('SubmissionTimestamp', ''), reverse=True)

        formatted_list = []
        for item in valid_applicants[:5]:
            inner_data = item.get('data', {})
            emp_mode = item.get('employmentMode', 'JOB')
            
            # --- EXTRACT NAMES ---
            f_name_obj = inner_data.get('firstName', {})
            l_name_obj = inner_data.get('lastName', {})
            f_name = f_name_obj.get('S', '') if isinstance(f_name_obj, dict) else str(f_name_obj)
            l_name = l_name_obj.get('S', '') if isinstance(l_name_obj, dict) else str(l_name_obj)
            
            full_name = f"{f_name} {l_name}".strip()
            if not full_name:
                full_name = "Unknown Applicant"

            # --- EXTRACT INCOME ---
            income_key = 'annualIncome' if emp_mode == 'JOB' else 'netAnnualIncome'
            raw_income = inner_data.get(income_key)
            display_amount = "0"
            if raw_income:
                display_amount = raw_income.get('S', '0') if isinstance(raw_income, dict) else str(raw_income)

            # --- NEW FIELDS FROM DYNAMODB ---
            # We assume your analysis Lambda saves these specific keys to the table
            credit_score = item.get('creditScore', "N/A")
            risk_level = item.get('risk_level', "Pending")  # Matches "High" in your JSON
            status = item.get('kyc_status', "Under Review")    # Matches "Rejected" in your JSON

            formatted_list.append({
                "ApplicationID": item.get('ApplicantID'),
                "Applicant": full_name,
                "LoanType": "Personal" if emp_mode == "JOB" else "Business",
                "Amount": display_amount,
                "Date": str(item.get('SubmissionTimestamp'))[:10],
                "CreditScore": credit_score,
                "RiskLevel": risk_level,    # <--- ADDED
                "Status": status            # <--- ADDED
            })

        return {
            'statusCode': 200,
            'headers': {
                'Content-Type': 'application/json',
                'Access-Control-Allow-Origin': '*'
            },
            'body': json.dumps(formatted_list, cls=DecimalEncoder)
        }

    except Exception as e:
        print(f"Error: {str(e)}")
        return {
            'statusCode': 500,
            'body': json.dumps({'error': str(e)})
        }
