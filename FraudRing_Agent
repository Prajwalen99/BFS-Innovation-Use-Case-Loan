import os
import json
import boto3
from botocore.config import Config
from boto3.dynamodb.conditions import Key
from datetime import datetime, timezone
import logging

from gremlin_python.driver.driver_remote_connection import DriverRemoteConnection
from gremlin_python.process.anonymous_traversal import traversal
from gremlin_python.process.graph_traversal import __
from gremlin_python.process.traversal import P, T

# Configure logging
logger = logging.getLogger()
logger.setLevel(logging.INFO)

# --- Configuration ---
boto_config = Config(connect_timeout=5, read_timeout=5, retries={'max_attempts': 2}, region_name='us-west-2')
NEPTUNE_ENDPOINT = os.environ.get('NEPTUNE_ENDPOINT')

dynamodb = boto3.resource('dynamodb', config=boto_config)
kyc_table = dynamodb.Table('ApplicantData')
dex_table = dynamodb.Table('DEX_Session_Store')

g = None

def get_g():
    global g
    if g is None:
        conn = DriverRemoteConnection(NEPTUNE_ENDPOINT, 'g', pool_size=10)
        g = traversal().withRemote(conn)
    return g

def calculate_confidence(factors, device_id):
    confidence = 0.70
    if device_id and device_id != 'UNKNOWN':
        confidence += 0.10
    if factors['linked_applicants_count'] > 0:
        confidence += 0.10
    if factors['cluster_size'] > 1:
        confidence += 0.05
    return min(0.99, confidence)

def generate_human_xai(factors, risk_analysis):
    score = risk_analysis['score']
    risk_level = risk_analysis['risk_level']
    findings = []
    
    if factors['shared_email_count'] > 1:
        findings.append(f"Email used across {factors['shared_email_count']} applications.")
    if factors['shared_device_count'] > 1:
        findings.append(f"Device linked to {factors['shared_device_count']} other accounts.")
    if factors['linked_applicants_count'] > 0:
        findings.append(f"Direct connection to {factors['linked_applicants_count']} other applicants.")
    if factors['cluster_size'] >= 4:
        findings.append(f"Part of an organized cluster of {factors['cluster_size']} entities.")

    return {
        'summary': f"Risk: {risk_level} (Score: {score}/100).",
        'details': findings or ["No suspicious overlaps detected."],
        'action': "Immediate manual verification required" if risk_level == "HIGH" else "Proceed with standard review"
    }

def lambda_handler(event, context):
    # --- UNIVERSAL CORS LOGIC ---
    # This captures the request origin and reflects it back to satisfy the browser's CORS policy
    request_headers = event.get('headers', {}) or {}
    # Handle casing (Origin vs origin)
    origin = next((request_headers[h] for h in request_headers if h.lower() == 'origin'), '*')

    cors_headers = {
        'Access-Control-Allow-Origin': origin,
        'Access-Control-Allow-Headers': 'Content-Type,X-Amz-Date,Authorization,X-Api-Key,X-Amz-Security-Token',
        'Access-Control-Allow-Methods': 'OPTIONS,POST,GET',
        'Access-Control-Allow-Credentials': 'true' # Required for authenticated requests
    }

    # Handle Pre-flight OPTIONS request (Crucial for API Gateway)
    if event.get('httpMethod') == 'OPTIONS':
        return {
            'statusCode': 204, # No Content
            'headers': cors_headers,
            'body': ''
        }

    live_logs = []
    def add_agent_log(msg): live_logs.append(f"Agent: {msg}")

    try:
        add_agent_log("Initializing underwriting session...")
        
        # Handle body parsing for different integration types
        body = {}
        if isinstance(event.get('body'), str):
            body = json.loads(event['body'])
        elif isinstance(event.get('body'), dict):
            body = event['body']
        
        applicant_id = body.get('ApplicantID') or event.get('ApplicantID')
        
        if not applicant_id:
            add_agent_log("Critical Failure: Missing Applicant Identity.")
            return {
                'statusCode': 400, 
                'headers': cors_headers, 
                'body': json.dumps({'error': 'Missing ID', 'Live Logs': live_logs})
            }

        # Data Fetching
        add_agent_log(f"Fetching data for {applicant_id}...")
        kyc_resp = kyc_table.query(KeyConditionExpression=Key('ApplicantID').eq(applicant_id), Limit=1)
        dex_resp = dex_table.query(IndexName='ApplicantID-Index', KeyConditionExpression=Key('ApplicantID').eq(applicant_id), Limit=1)
        
        if not kyc_resp.get('Items'):
            add_agent_log("Logic Sync: Status verified as Rejected (Not Found).")
            return {
                'statusCode': 404, 
                'headers': cors_headers, 
                'body': json.dumps({'error': 'Not Found', 'Live Logs': live_logs})
            }

        item = kyc_resp['Items'][0]
        email = str(item.get('data', {}).get('email', '')).lower()
        device = dex_resp['Items'][0].get('device_id', 'UNKNOWN') if dex_resp.get('Items') else 'UNKNOWN'

        # Graph Analytics
        g_source = get_g()
        factors = {
            'linked_applicants_count': g_source.V().has('applicant', 'id', applicant_id).both().both().hasLabel('applicant').has('id', P.neq(applicant_id)).dedup().count().next(),
            'shared_email_count': g_source.V().has('identity', 'val', email).in_('IDENTIFIED_BY').count().next(),
            'shared_device_count': g_source.V().has('device', 'val', device).in_('ACCESSED_FROM').count().next(),
            'cluster_size': g_source.V().has('applicant', 'id', applicant_id).repeat(__.both().simplePath()).times(3).dedup().count().next()
        }

        # Logic & Scoring
        score = min(100, (factors['shared_email_count'] * 20) + (factors['shared_device_count'] * 15) + (factors['linked_applicants_count'] * 10))
        risk_level = "HIGH" if score >= 70 else "MEDIUM" if score >= 40 else "LOW"
        conf_val = calculate_confidence(factors, device)
        xai_human = generate_human_xai(factors, {'score': score, 'risk_level': risk_level})

        status = "Rejected" if risk_level == "HIGH" else "Flagged" if risk_level == "MEDIUM" else "Verified"
        add_agent_log(f"Logic Sync: Status verified as {status}.")

        return {
            'statusCode': 200,
            'headers': cors_headers,
            'body': json.dumps({
                "ApplicantID": applicant_id,
                "score": score,
                "risk_level": risk_level,
                "confidence_interval": conf_val,
                "Reasoning": f"Identity flagged as {risk_level.lower()} risk.",
                "xai_reasoning": xai_human,
                "Live Logs": live_logs[:6]
            })
        }
        
    except Exception as e:
        logger.error(f"Error: {str(e)}")
        return {
            'statusCode': 500, 
            'headers': cors_headers, 
            'body': json.dumps({'error': str(e), 'Live Logs': live_logs})
        }
