import boto3
import json
from datetime import datetime, timedelta
from boto3.dynamodb.conditions import Attr

def lambda_handler(event, context):
    dynamodb = boto3.resource('dynamodb')
    table = dynamodb.Table('ApplicantData')
    
    # 1. Robust Payload Parsing
    # Handles API Gateway (string body) and Lambda Console (dict)
    body = event
    if isinstance(event.get('body'), str):
        try:
            body = json.loads(event['body'])
        except Exception:
            body = {}
    
    # Get status and normalize (strip spaces)
    status_filter = body.get('kyc_status')
    if status_filter:
        status_filter = status_filter.strip()

    # 2. Setup Time Range (Last 7 Days)
    today = datetime.utcnow()
    chart_dict = {}
    for i in range(7):
        date_str = (today - timedelta(days=i)).strftime('%Y-%m-%d')
        chart_dict[date_str] = 0
        
    # Start date string for comparison
    start_date_filter = (today - timedelta(days=7)).strftime('%Y-%m-%dT00:00:00')

    try:
        # 3. Build Dynamic Filter
        # Always filter by date first
        filter_exp = Attr('SubmissionTimestamp').gte(start_date_filter)
        
        # Only add status filter if it exists in the payload
        if status_filter:
            filter_exp = filter_exp & Attr('kyc_status').eq(status_filter)

        # 4. Scan Table (with Pagination support)
        items = []
        scan_kwargs = {'FilterExpression': filter_exp}
        
        # Loop handles cases where table > 1MB
        while True:
            response = table.scan(**scan_kwargs)
            items.extend(response.get('Items', []))
            
            # If LastEvaluatedKey exists, there is more data to scan
            if 'LastEvaluatedKey' in response:
                scan_kwargs['ExclusiveStartKey'] = response['LastEvaluatedKey']
            else:
                break

        # 5. Aggregate Counts into the dictionary
        for item in items:
            ts = item.get('SubmissionTimestamp', '')
            date_key = ts[:10]  # Extracts YYYY-MM-DD
            if date_key in chart_dict:
                chart_dict[date_key] += 1

        # 6. Format for Chart.js / Frontend
        final_data = [
            {"date": d, "applicants": chart_dict[d]} 
            for d in sorted(chart_dict.keys())
        ]

        return {
            'statusCode': 200,
            'headers': {
                'Content-Type': 'application/json',
                'Access-Control-Allow-Origin': '*'
            },
            'body': json.dumps(final_data)
        }

    except Exception as e:
        print(f"Error occurred: {str(e)}")
        return {
            'statusCode': 500,
            'body': json.dumps({'error': "Internal Server Error", "details": str(e)})
        }
